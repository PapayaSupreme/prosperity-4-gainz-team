   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Prosperity 4 Tutorial Round Starter\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook gives a quick first pass on spread behavior and price dynamics for `EMERALDS` and `TOMATOES`.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import plotly.express as px\\n\",\n",
    "    \"\\n\",\n",
    "    \"repo_root = Path.cwd().resolve().parents[1] if Path.cwd().name == 'analysis' else Path.cwd().resolve()\\n\",\n",
    "    \"if str(repo_root) not in sys.path:\\n\",\n",
    "    \"    sys.path.insert(0, str(repo_root))\\n\",\n",
    "    \"\\n\",\n",
    "    \"from prosperity4.analysis.data import read_all_tutorial_prices, read_all_tutorial_trades\\n\",\n",
    "    \"\\n\",\n",
    "    \"prices = read_all_tutorial_prices()\\n\",\n",
    "    \"trades = read_all_tutorial_trades()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'Prices shape: {prices.shape}')\\n\",\n",
    "    \"print(f'Trades shape: {trades.shape}')\\n\",\n",
    "    \"prices.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"df = prices.copy()\\n\",\n",
    "    \"df['spread'] = df['ask_price_1'] - df['bid_price_1']\\n\",\n",
    "    \"df['mid'] = (df['ask_price_1'] + df['bid_price_1']) / 2\\n\",\n",
    "    \"\\n\",\n",
    "    \"spread_stats = (\\n\",\n",
    "    \"    df.groupby('product')['spread']\\n\",\n",
    "    \"    .agg(['count', 'mean', 'median', 'std', 'min', 'max'])\\n\",\n",
    "    \"    .sort_index()\\n\",\n",
    "    \")\\n\",\n",
    "    \"spread_stats\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"sample = (\\n\",\n",
    "    \"    df.sort_values(['product', 'timestamp'])\\n\",\n",
    "    \"    .groupby('product', as_index=False, group_keys=False)\\n\",\n",
    "    \"    .head(3000)\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig_mid = px.line(sample, x='timestamp', y='mid', color='product', title='Mid Price (first 3000 points per product)')\\n\",\n",
    "    \"fig_mid.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"sample_spread = (\\n\",\n",
    "    \"    df.sort_values(['product', 'timestamp'])\\n\",\n",
    "    \"    .groupby('product', as_index=False, group_keys=False)\\n\",\n",
    "    \"    .head(3000)\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig_spread = px.line(sample_spread, x='timestamp', y='spread', color='product', title='Bid/Ask Spread (first 3000 points per product)')\\n\",\n",
    "    \"fig_spread.show()\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
